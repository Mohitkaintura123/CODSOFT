 preds = np.log(preds + 1e-7) / temperature\n","        exp_preds = np.exp(preds)\n","        preds = exp_preds / np.sum(exp_preds)\n","\n","        # Sample next character\n","        next_index = np.random.choice(len(chars), p=preds)\n","        next_char = idx_to_char[next_index]\n","\n","        # Update text window\n","        generated_extension += next_char\n","        seed_text = seed_text[1:] + next_char\n","\n","    # Return the clean combination of the user's prompt and the AI's generation\n","    return f\"{original_prompt}{generated_extension}\"\n","\n","# 2. Build the Graphical Interface\n","interface = gr.Interface(\n","    fn=generate_with_ui,\n","    inputs=[\n","        gr.Textbox(lines=2, placeholder=\"Type the start of a research sentence...\", label=\"Your Prompt\"),\n","        gr.Slider(minimum=0.1, maximum=1.0, value=0.3, step=0.1, label=\"Creativity (Temperature)\"),\n","        gr.Slider(minimum=100, maximum=1000, value=400, step=50, label=\"Generation Length (Characters)\")\n","    ],\n","    outputs=gr.Textbox(lines=8, label=\"AI Generated Completion\"),\n","    title=\"🤖 Auto-Complete LSTM Text Generator\",\n","    description=\"Trained entirely from scratch on Hugging Face ML research papers. Type a prompt and watch the LSTM complete it!\"\n",")\n","\n","# 3. Launch the UI! (share=True creates a temporary public link)\n","interface.launch(share=True, debug=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"TfnakJPd8aNP","executionInfo":{"status":"ok","timestamp":1776236931185,"user_tz":-330,"elapsed":454450,"user":{"displayName":"rohit Kaintura","userId":"12409605283824428436"}},"outputId":"affd8ab4-f1b6-4ff6-8f12-4f25d74664f0"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: gradio in /usr/local/lib/python3.12/dist-packages (5.50.0)\n","Requirement already satisfied: aiofiles<25.0,>=22.0 in /usr/local/lib/python3.12/dist-packages (from g